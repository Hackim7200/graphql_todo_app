# AppSync GraphQL — REST Client / httpYac
# Copy AppSyncGraphQlUrl from CDK outputs into @url. Use Cognito ID token (token_use=id) as @token.
# Subscriptions (onTodoChanged) require the WebSocket URL from AppSyncRealtimeUrl — not plain POST here.

@url = https://d2ajcwzd35bstjzzsevh3nzday.appsync-api.eu-west-2.amazonaws.com/graphql
# Cognito sub (ID token `sub`) for onTodoChanged(owner); must match the signed-in user.
@owner = a672e224-a011-70b9-09cc-8b2c66fc9337 // this is user id 
@token = eyJraWQiOiJJMGhPS1F3RmxhUEN0bms4YTBzK0NSeXJtNDA0cVIzUlRJS1o1alBoRzkwPSIsImFsZyI6IlJTMjU2In0..J3YbBWWy4IvF0izGcWclLIEU-UujmUV4lUJg2CLxBtswOaemnX7xBjwzeIM1-f3ip5QluxRIn9zwoItMOY3pNIhvhNj3SVUFHpzBStouvcNnfBqwCtXgiW2ZJbqtIPzHB-p9IeSHBTdhe7k6oNluudTQ7zgZDbwM8e9jAGwGLGzH9TuZgjP1y6vXmZ3Qp-dkErJNGb_HyKibDevuo7wF0-wCUdjQDU3NppgH1d2yKHMJEegRycVowY_nQIsNntB4WzLzGbb5ElQ5rgc7-HftefGSusJusjgqZDt6HS1M_1bXZnmcDYP6GioonM1XUoQ-pnnink0CpEKJyZW8hh5XrQ

# Subscription over WSS (not POST): subscription OnTodoChanged($owner: String!) { onTodoChanged(owner: $owner) { id title description isCompleted owner createdAt updatedAt } }

### Create todo
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation CreateTodo($input: CreateTodoInput!) { createTodo(input: $input) { id title description isCompleted owner createdAt updatedAt } }",
  "variables": {
    "input": {
      "title": "Tesing 2t",
      "description": "Created from REST Client",
      "isCompleted": false
    }
  }
}

### Get one todo by id (replace id from create or list response)
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "query GetTodo($id: String!) { getTodo(id: $id) { id title description isCompleted owner createdAt updatedAt } }",
  "variables": {
    "id": "00000000-0000-4000-8000-000000000000"
  }
}

### List todos (paginated)
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "query ListTodos($limit: Int, $nextToken: String) { listTodos(limit: $limit, nextToken: $nextToken) { todos { id title description isCompleted owner createdAt updatedAt } nextToken } }",
  "variables": {
    "limit": 10,
    "nextToken": null
  }
}

### Update todo (replace id with a real todo id)
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation UpdateTodo($input: UpdateTodoInput!) { updateTodo(input: $input) { id title description isCompleted owner createdAt updatedAt } }",
  "variables": {
    "input": {
      "id": "00000000-0000-4000-8000-000000000000",
      "title": "Updated title",
      "description": "Updated from REST Client",
      "isCompleted": true
    }
  }
}

### Delete todo (replace id with a real todo id)
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation DeleteTodo($id: String!) { deleteTodo(id: $id) { id title description isCompleted owner createdAt updatedAt } }",
  "variables": {
    "id": "1d5c2d3f-d8b3-4ace-bd94-496f45a4eea3"
  }
}