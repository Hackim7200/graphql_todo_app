# Cognito sub (ID token `sub`) for onTodoChanged(owner); must match the signed-in user.
@token = eyJraWQiOiJJMGhPS1F3RmxhUEN0bms4YTBzK0NSeXJtNDA0cVIzUlRJS1o1alBoRzkwPSIsImFsZyI6IlJTMjU2In0..bx8c1D4vLbJ-craAck9VaQ4hZ29YL4J8qTlLFsQ1Mc0UtPDePdooxzGlOEl9krHJkt4sCIKmEetmcfJIjcW9vbfGqwo2kINaqsPixCsZdJ9dTZGfEjMP4-0FCwctIIxsoZ6jlMHcdYi-Iap9UgdzYTTU_w-TXkxpRuP4WH1xevP0k4GZGLBnq9KMFH9WEup0HLGlCHqdOavsmAdQSs3pmnRPJXWlJyBu1349wA9eZevXlfrN8_obnReJ8PbOeB0nTalkszqvPOxS07T8UJVfPjX4-gRQOjQczm6FNaKQMBOP2OlrRDMpANEQQG4OZSxYlCbghJYefJ4Yp3larHNAHA


# Subscription over WSS (not POST): subscription OnTodoChanged($owner: String!) { onTodoChanged(owner: $owner) { id title isCompleted owner createdAt updatedAt } }

### Create todo
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation CreateTodo($input: CreateTodoInput!) { createTodo(input: $input) { id title isCompleted owner createdAt updatedAt } }",
  "variables": {
    "input": {
      "title": "Testing 22",
      "isCompleted": false
    }
  }
}
### List todos (paginated)
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "query ListTodos($limit: Int, $nextToken: String) { listTodos(limit: $limit, nextToken: $nextToken) { todos { id title isCompleted owner createdAt updatedAt } nextToken } }",
  "variables": {
    "limit": 10,
    "nextToken": null
  }
}

### Get one todo by id (replace id from create or list response)
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "query GetTodo($id: ID!) { getTodo(id: $id) { id title isCompleted owner createdAt updatedAt } }",
  "variables": {
    "id": "73553b27-d36f-4192-b119-0a3e308ad54d"
  }
}



### Update todo (replace id with a real todo id)
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation UpdateTodo($input: UpdateTodoInput!) { updateTodo(input: $input) { id title isCompleted owner createdAt updatedAt } }",
  "variables": {
    "input": {
      "id": "73553b27-d36f-4192-b119-0a3e308ad54d",
      "title": "Updated title",
      "isCompleted": true
    }
  }
}

### Delete todo (replace id with a real todo id)
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation DeleteTodo($id: ID!) { deleteTodo(id: $id) { id title isCompleted owner createdAt updatedAt } }",
  "variables": {
    "id": "73553b27-d36f-4192-b119-0a3e308ad54d"
  }
}
