# Subscription over WSS (not POST): subscription OnTodoChanged { onTodoChanged { id title isCompleted owner createdAt updatedAt } }

### Create todo
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation CreateTodo($input: CreateTodoInput!) { createTodo(input: $input) { id title isCompleted owner createdAt updatedAt } }",
  "variables": {
    "input": {
      "id": "003",
      "title": "new todo item",
      "isCompleted": false
    }
  }
}

### List todos (paginated)
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "query ListTodos($limit: Int, $nextToken: String) { listTodos(limit: $limit, nextToken: $nextToken) { items { id title isCompleted owner createdAt updatedAt } nextToken } }",
  "variables": {
    "limit": 50,
    "nextToken": null
  }
}

### Get one todo by id (replace id from create or list response)
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "query GetTodo($id: ID!) { getTodo(id: $id) { id title isCompleted owner createdAt updatedAt } }",
  "variables": {
    "id": "001"
  }
}

### Update todo (replace id with a real todo id)
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation UpdateTodo($input: UpdateTodoInput!) { updateTodo(input: $input) { id title isCompleted owner createdAt updatedAt } }",
  "variables": {
    "input": {
      "id": "48e47062-3bef-4512-9062-f28d27d587f8",
      "title": "Fatty cat",
      "isCompleted": true
    }
  }
}

### Delete todo (replace id with a real todo id)
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation DeleteTodo($id: ID!) { deleteTodo(id: $id) { id title isCompleted owner createdAt updatedAt } }",
  "variables": {
    "id": "48e47062-3bef-4512-9062-f28d27d587f8"
  }
}
