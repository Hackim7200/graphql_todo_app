@todoId = 001

# onPomodoroChanged { todoId id title isCompleted duration owner createdAt updatedAt }

### Create pomodoro (under @todoId)
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation CreatePomodoro($input: CreatePomodoroInput!) { createPomodoro(input: $input) { todoId id title isCompleted duration owner createdAt updatedAt } }",
  "variables": {
    "input": {
      "todoId": "{{todoId}}",
      "id": "pom-001",
      "title": "Focus block",
      "duration": 1500,
      "isCompleted": false
    }
  }
}

### List pomodoros for a todo
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "query ListPomodoros($todoId: ID!, $limit: Int, $nextToken: String) { listPomodoros(todoId: $todoId, limit: $limit, nextToken: $nextToken) { items { todoId id title isCompleted duration owner createdAt updatedAt } nextToken } }",
  "variables": {
    "todoId": "{{todoId}}",
    "limit": 50,
    "nextToken": null
  }
}

### Get pomodoro by todo + id
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "query GetPomodoro($todoId: ID!, $id: ID!) { getPomodoro(todoId: $todoId, id: $id) { todoId id title isCompleted duration owner createdAt updatedAt } }",
  "variables": {
    "todoId": "{{todoId}}",
    "id": "pom-001"
  }
}

### Update pomodoro
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation UpdatePomodoro($input: UpdatePomodoroInput!) { updatePomodoro(input: $input) { todoId id title isCompleted duration owner createdAt updatedAt } }",
  "variables": {
    "input": {
      "todoId": "{{todoId}}",
      "id": "pom-001",
      "title": "Focus block (updated)",
      "duration": 1800,
      "isCompleted": true
    }
  }
}

### Delete pomodoro
POST {{url}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation DeletePomodoro($todoId: ID!, $id: ID!) { deletePomodoro(todoId: $todoId, id: $id) { todoId id title isCompleted duration owner createdAt updatedAt } }",
  "variables": {
    "todoId": "{{todoId}}",
    "id": "pom-001"
  }
}

